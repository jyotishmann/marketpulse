# .env.example
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
# This file IS committed — it shows what variables are required.

# Database
# For Docker Compose: use service name 'db' as the host
# For local (no Docker): use 'localhost'
DATABASE_URL=postgresql://marketpulse:marketpulse@db:5432/marketpulse

# Redis 
# For Docker Compose: use service name 'redis' as the host
# For local (no Docker): use 'localhost'
REDIS_URL=redis://redis:6379/0

# Tickers & Data Sources
# Comma-separated. No spaces. Any symbol yfinance supports.
TICKERS=AAPL,GOOGL,MSFT,TSLA

# Free RSS feeds — no sign-up required
RSS_FEED_URLS=https://feeds.finance.yahoo.com/rss/2.0/headline?s=AAPL&region=US&lang=en-US,https://feeds.finance.yahoo.com/rss/2.0/headline?s=MSFT&region=US&lang=en-US

# Schedule (in minutes) 
SCHEDULE_STOCK_MINUTES=15
SCHEDULE_NEWS_MINUTES=30
SCHEDULE_ML_MINUTES=60

# Cache TTLs (in seconds) 
CACHE_TTL_PRICES=300
CACHE_TTL_INDICATORS=300
CACHE_TTL_SIGNALS=3600
CACHE_TTL_NEWS=600

# Machine Learning 
MODEL_DIR=./models
ML_LOOKBACK_DAYS=90
ML_ANOMALY_CONTAMINATION=0.05

# API Server 
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Dashboard 
# Inside Docker Compose, Streamlit reaches the API at http://api:8000
# Running locally: change to http://localhost:8000/api/v1
DASHBOARD_API_URL=http://api:8000/api/v1